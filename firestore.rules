// Regras de Segurança do Firestore para EzFleet
// Copie e cole isso no Firebase Console > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuários podem acessar apenas seus próprios dados
    match /users/{userId} {
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Permitir leitura de dados públicos se necessário (opcional)
    // match /public/{document=**} {
    //   allow read: if true;
    //   allow write: if false;
    // }
  }
}